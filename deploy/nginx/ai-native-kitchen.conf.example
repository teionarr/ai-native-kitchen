# nginx snippet for hosting the kitchen behind your existing nginx install on the VM.
#
# Install:
#   sudo cp deploy/nginx/ai-native-kitchen.conf.example /etc/nginx/sites-available/ai-native-kitchen.conf
#   sudo $EDITOR /etc/nginx/sites-available/ai-native-kitchen.conf   # set YOUR_DOMAIN_HERE everywhere
#   sudo ln -s /etc/nginx/sites-available/ai-native-kitchen.conf /etc/nginx/sites-enabled/
#   sudo nginx -t   # MUST pass
#   sudo systemctl reload nginx
#
# Assumes existing Let's Encrypt automation handles certs (via certbot or similar).
# DO NOT install a second cert manager.

# ---- API endpoint ---------------------------------------------------------------------------

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name api.YOUR_DOMAIN_HERE;

    # TLS — managed by your existing certbot
    ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN_HERE/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN_HERE/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    # Hide nginx version in error pages
    server_tokens off;

    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
    }

    access_log /var/log/nginx/ai-native-kitchen-api.access.log;
    error_log  /var/log/nginx/ai-native-kitchen-api.error.log warn;
}

server {
    listen 80;
    listen [::]:80;
    server_name api.YOUR_DOMAIN_HERE;
    return 301 https://$host$request_uri;
}

# ---- Static brief-host ----------------------------------------------------------------------

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name briefs.YOUR_DOMAIN_HERE;

    ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN_HERE/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN_HERE/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    root /var/lib/ai-native-kitchen/briefs;

    add_header Content-Security-Policy "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' https:" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    server_tokens off;

    # Only serve .html files; everything else returns 404
    location ~ \.html$ {
        try_files $uri =404;
    }

    location / {
        return 404;
    }

    access_log /var/log/nginx/ai-native-kitchen-briefs.access.log;
    error_log  /var/log/nginx/ai-native-kitchen-briefs.error.log warn;
}

server {
    listen 80;
    listen [::]:80;
    server_name briefs.YOUR_DOMAIN_HERE;
    return 301 https://$host$request_uri;
}
